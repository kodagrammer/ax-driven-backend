#!/bin/sh
# pre-commit hook — 커밋 전 기본 검증
#
# 검증 항목:
#   1. 민감 파일 커밋 방지 (.env, credentials, secret key 등)
#   2. 충돌 마커 잔류 방지 (<<<<<<<, =======, >>>>>>>)
#   3. 대용량 파일 방지 (기본 5MB 초과)
#   4. 디버그 코드 방지 (스택별 확장 가능)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

HAS_ERROR=0

# --- Error: 민감 파일 커밋 방지 ---
SENSITIVE_PATTERNS=".env .env.local .env.production .env.staging
credentials.json service-account.json
id_rsa id_rsa.pub id_ed25519 id_ed25519.pub
*.pem *.key *.p12 *.pfx *.jks
.secret secret.yml secrets.yml
kubeconfig"

for FILE in $STAGED_FILES; do
  BASENAME=$(basename "$FILE")
  for PATTERN in $SENSITIVE_PATTERNS; do
    case "$PATTERN" in
      \*.*)
        # 확장자 패턴 매칭
        EXT=$(echo "$PATTERN" | sed 's/\*//')
        case "$BASENAME" in
          *"$EXT")
            echo "[ERROR] 민감 파일이 스테이징되어 있습니다: $FILE"
            echo "  .gitignore에 추가하거나 git reset HEAD $FILE 로 제거해주세요."
            HAS_ERROR=1
            ;;
        esac
        ;;
      *)
        # 정확히 파일명 일치
        if [ "$BASENAME" = "$PATTERN" ]; then
          echo "[ERROR] 민감 파일이 스테이징되어 있습니다: $FILE"
          echo "  .gitignore에 추가하거나 git reset HEAD $FILE 로 제거해주세요."
          HAS_ERROR=1
        fi
        ;;
    esac
  done
done

# --- Error: 충돌 마커 잔류 방지 ---
for FILE in $STAGED_FILES; do
  if git show ":$FILE" 2>/dev/null | grep -qE '^(<{7}|={7}|>{7})'; then
    echo "[ERROR] 충돌 마커가 남아있습니다: $FILE"
    echo "  충돌을 해결한 후 다시 커밋해주세요."
    HAS_ERROR=1
  fi
done

# --- Error: 대용량 파일 방지 (5MB 초과) ---
MAX_SIZE=$((5 * 1024 * 1024))

for FILE in $STAGED_FILES; do
  FILE_SIZE=$(git cat-file -s ":$FILE" 2>/dev/null || echo 0)
  if [ "$FILE_SIZE" -gt "$MAX_SIZE" ]; then
    SIZE_MB=$(echo "$FILE_SIZE" | awk '{printf "%.1f", $1/1024/1024}')
    echo "[ERROR] 대용량 파일입니다 (${SIZE_MB}MB): $FILE"
    echo "  5MB 초과 파일은 .gitignore에 추가하거나 Git LFS를 사용해주세요."
    HAS_ERROR=1
  fi
done

# --- Warning: 디버그 코드 방지 (스택별 확장 가능) ---
HAS_DEBUG_WARNING=0

for FILE in $STAGED_FILES; do
  # 바이너리 파일 건너뜀
  if git show ":$FILE" 2>/dev/null | file - | grep -q binary; then
    continue
  fi

  # 새로 추가된 라인(+)만 검사 — 기존 코드의 디버그 코드는 무시
  MATCHES=$(git diff --cached -- "$FILE" | grep '^+' | grep -vE '^\+\+\+' | grep -nE \
    'console\.log|debugger;|System\.out\.print|binding\.pry|import pdb|breakpoint\(\)' \
    2>/dev/null || true)

  if [ -n "$MATCHES" ]; then
    if [ "$HAS_DEBUG_WARNING" -eq 0 ]; then
      echo ""
      echo "[WARNING] 디버그 코드가 감지되었습니다. (새로 추가된 라인만 검사)"
      HAS_DEBUG_WARNING=1
    fi
    echo "  $FILE:"
    echo "$MATCHES" | sed 's/^/    /'
  fi
done

if [ "$HAS_DEBUG_WARNING" -eq 1 ]; then
  echo ""
  echo "  (Warning이므로 커밋은 중단되지 않습니다. 불필요한 코드라면 제거 후 다시 커밋해주세요.)"
  echo ""
fi

if [ "$HAS_ERROR" -ne 0 ]; then
  echo ""
  exit 1
fi

exit 0
